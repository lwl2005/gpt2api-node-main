# 服务器端口
PORT=3000

# Token 文件路径
TOKEN_FILE=./token.json

# 模型列表文件路径
MODELS_FILE=./models.json

# HTTP 代理（可选，用于 token 刷新）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 负载均衡策略
# round-robin: 轮询（默认）
# random: 随机选择
# least-used: 最少使用
LOAD_BALANCE_STRATEGY=round-robin

# 代理请求最大重试次数（故障转移到不同 Token）
MAX_RETRIES=3

# API Key 速率限制（每分钟最大请求数）
RATE_LIMIT_RPM=60

# ==================== 自动检测监控 ====================

# 活跃 Token 检测间隔（毫秒）
# 默认1小时，每隔这个时间对所有活跃 Token 做真实 API 调用测试
# 1小时 = 3600000, 2小时 = 7200000, 3小时 = 10800000
MONITOR_INTERVAL=3600000

# 已封停 Token 复测间隔（毫秒）
# 默认2小时，每隔这个时间重新测试已封停的 Token，通过则自动恢复
# 1小时 = 3600000, 2小时 = 7200000, 3小时 = 10800000
RECOVERY_INTERVAL=7200000

# Token 过期前自动刷新缓冲（毫秒，默认10分钟）
REFRESH_BUFFER=600000

# 连续检测失败几次后自动封停（默认2次）
MAX_FAILURES=2
